# Copy this file to .env.local and paste your Supabase project values.
#   cp .env.local.example .env.local
#
# Find these in the Supabase dashboard:
#   Project Settings -> API
#     Project URL      -> NEXT_PUBLIC_SUPABASE_URL
#     Project API keys -> anon / public -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# These are the PUBLIC keys and are safe to expose to the browser. RLS is what
# protects your data. Never put the service_role key in a NEXT_PUBLIC_ var.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
